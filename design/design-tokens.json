  "typography": {
    "font-family": {
      "sans": "\"Airbnb Cereal VF\", \"Cereal\", \"Inter\", -apple-system, BlinkMacSystemFont, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial, sans-serif",
      "display": "\"Fraunces\", \"Source Serif Pro\", Georgia, serif",
      "mono": "\"JetBrains Mono\", \"SF Mono\", \"Menlo\", \"Consolas\", monospace"
    },
    "scale": {
      "4xl":   { "size": "2.50rem",  "weight": 700, "lh": 1.10, "tracking": "-0.5px" },
      "3xl":   { "size": "1.75rem",  "weight": 700, "lh": 1.18, "tracking": "-0.44px" },
      "2xl":   { "size": "1.38rem",  "weight": 600, "lh": 1.20, "tracking": "-0.40px" },
      "xl":    { "size": "1.25rem",  "weight": 600, "lh": 1.25, "tracking": "-0.18px" },
      "lg":    { "size": "1.13rem",  "weight": 600, "lh": 1.33, "tracking": "-0.10px" },
      "md":    { "size": "1.00rem",  "weight": 500, "lh": 1.25, "tracking": "0" },
      "sm":    { "size": "0.88rem",  "weight": 400, "lh": 1.43, "tracking": "0" },
      "xs":    { "size": "0.81rem",  "weight": 400, "lh": 1.23, "tracking": "0" },
      "2xs":   { "size": "0.75rem",  "weight": 500, "lh": 1.33, "tracking": "0" },
      "3xs":   { "size": "0.69rem",  "weight": 600, "lh": 1.18, "tracking": "0.08px" },
      "micro": { "size": "0.50rem",  "weight": 700, "lh": 1.25, "tracking": "0.32px" }
    }
  },
  "space": {
    "0":   "0",
    "px":  "1px",
    "1":   "0.25rem",
    "1-5": "0.375rem",
    "2":   "0.5rem",
    "2-5": "0.625rem",
    "3":   "0.75rem",
    "4":   "1rem",
    "5":   "1.25rem",
    "6":   "1.5rem",
    "8":   "2rem",
    "10":  "2.5rem",
    "12":  "3rem",
    "16":  "4rem",
    "20":  "5rem",
    "24":  "6rem",
    "32":  "8rem"
  },
  "radius": {
    "0":    "0",
    "xs":   "4px",
    "sm":   "8px",
    "md":   "12px",
    "lg":   "14px",
    "xl":   "20px",
    "2xl":  "28px",
    "3xl":  "32px",
    "pill": "9999px",
    "full": "50%"
  },
  "stroke": {
    "0":   "0",
    "1":   "1px",
    "1-5": "1.5px",
    "2":   "2px",
    "3":   "3px",
    "4":   "4px"
  },
  "shadow": {
    "light": {
      "0": "none",
      "1": "rgba(0, 0, 0, 0.02) 0px 0px 0px 1px, rgba(0, 0, 0, 0.04) 0px 2px 6px, rgba(0, 0, 0, 0.10) 0px 4px 8px",
      "2": "rgba(0, 0, 0, 0.03) 0px 0px 0px 1px, rgba(0, 0, 0, 0.06) 0px 4px 12px, rgba(0, 0, 0, 0.12) 0px 8px 20px",
      "3": "rgba(0, 0, 0, 0.04) 0px 0px 0px 1px, rgba(0, 0, 0, 0.08) 0px 6px 16px, rgba(0, 0, 0, 0.14) 0px 12px 32px",
      "4": "rgba(0, 0, 0, 0.04) 0px 0px 0px 1px, rgba(0, 0, 0, 0.10) 0px 10px 24px, rgba(0, 0, 0, 0.18) 0px 20px 48px",
      "5": "rgba(0, 0, 0, 0.06) 0px 0px 0px 1px, rgba(0, 0, 0, 0.14) 0px 16px 32px, rgba(0, 0, 0, 0.24) 0px 32px 80px"
    },
    "dark": {
      "0": "none",
      "1": "rgba(0, 0, 0, 0.40) 0px 0px 0px 1px, rgba(0, 0, 0, 0.40) 0px 4px 12px",
      "2": "rgba(0, 0, 0, 0.44) 0px 0px 0px 1px, rgba(0, 0, 0, 0.48) 0px 8px 20px",
      "3": "rgba(0, 0, 0, 0.48) 0px 0px 0px 1px, rgba(0, 0, 0, 0.56) 0px 12px 32px",
      "4": "rgba(0, 0, 0, 0.50) 0px 0px 0px 1px, rgba(0, 0, 0, 0.64) 0px 20px 48px",
      "5": "rgba(0, 0, 0, 0.56) 0px 0px 0px 1px, rgba(0, 0, 0, 0.72) 0px 32px 80px"
    }
  },
  "motion": {
    "ease": {
      "out":        "cubic-bezier(0.22, 1, 0.36, 1)",
      "in-out":     "cubic-bezier(0.65, 0, 0.35, 1)",
      "in":         "cubic-bezier(0.55, 0, 1, 0.45)",
      "spring":     "cubic-bezier(0.34, 1.56, 0.64, 1)",
      "standard":   "cubic-bezier(0.4, 0, 0.2, 1)"
    },
    "duration": {
      "instant":    "80ms",
      "fast":       "120ms",
      "base":       "200ms",
      "slow":       "320ms",
      "elaborate":  "480ms",
      "scan-loop":  "1600ms"
    }
  },
  "icon": {
    "size": {
      "xs":  "12px",
      "sm":  "16px",
      "md":  "20px",
      "lg":  "24px",
      "xl":  "32px",
      "2xl": "48px"
    }
  }
}
