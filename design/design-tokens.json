      "text-link": "#6ea6ff",
      "text-brand": "#ff4d6d",

      "border": "#2a2a2e",
      "border-strong": "#3b3b40",
      "border-focus": "#ededed",
      "border-brand": "#ff4d6d",

      "success": "#2fcf34",
      "success-soft": "rgba(47, 207, 52, 0.14)",
      "warning": "#f5b946",
      "warning-soft": "rgba(245, 185, 70, 0.16)",
