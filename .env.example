# =============================================================================
# Grocery Inventory & Savings Management System
# Copy this file to .env, then fill in the values below.
# This file is safe to commit. Never commit your real .env.
# =============================================================================

# -----------------------------------------------------------------------------
# Required: App access
# -----------------------------------------------------------------------------
# Generate once with:
# python -c "import secrets; print(secrets.token_urlsafe(32))"
# The first browser login uses the email/password below.
# INITIAL_ADMIN_TOKEN remains useful for integrations and direct API calls.
INITIAL_ADMIN_TOKEN=replace_with_a_long_random_token
INITIAL_ADMIN_NAME=Admin
INITIAL_ADMIN_EMAIL=admin@localhost
INITIAL_ADMIN_PASSWORD=replace_with_a_strong_password
SESSION_SECRET=replace_with_another_long_random_secret
SESSION_COOKIE_SECURE=0

# -----------------------------------------------------------------------------
# Required: Primary OCR provider
# -----------------------------------------------------------------------------
GEMINI_API_KEY=replace_with_your_gemini_api_key
GEMINI_MODEL=gemini-2.5-flash

# -----------------------------------------------------------------------------
# Optional: Secondary OCR fallback
# Leave blank if you do not want OpenAI fallback.
# -----------------------------------------------------------------------------
OPENAI_API_KEY=
OPENAI_OCR_MODEL=gpt-4.1-mini

# -----------------------------------------------------------------------------
# Optional: Ollama fallback OCR
# Default points at the Ollama container started by docker compose.
# If you run Ollama on another machine, replace with that LAN URL.
# Example: http://192.168.1.50:11434
# -----------------------------------------------------------------------------
OLLAMA_ENDPOINT=http://ollama:11434
OLLAMA_MODEL=llava:7b
OLLAMA_TIMEOUT_SECONDS=180

# -----------------------------------------------------------------------------
# App runtime
# -----------------------------------------------------------------------------
FLASK_ENV=production
FLASK_PORT=8080
FLASK_DEBUG=0
DATABASE_URL=sqlite:////data/db/grocery.db
RECOMMENDATION_TIME=08:00
RECEIPT_RETENTION_MONTHS=12

# -----------------------------------------------------------------------------
# MQTT / Home Assistant
# Use the built-in mqtt container by default.
# If Home Assistant uses another broker, point MQTT_BROKER there instead.
# -----------------------------------------------------------------------------
MQTT_BROKER=mqtt
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_CLIENT_ID=grocery-backend

# -----------------------------------------------------------------------------
# Optional operator notes for Home Assistant integration
# These are placeholders for the person deploying the app.
# They are not currently required by the backend code.
# -----------------------------------------------------------------------------
HOME_ASSISTANT_BASE_URL=http://homeassistant.local:8123
HOME_ASSISTANT_DASHBOARD_PATH=/lovelace/grocery

# -----------------------------------------------------------------------------
# Optional: Telegram bot
# Needed only if you want to send receipts through Telegram.
# TELEGRAM_WEBHOOK_BASE_URL must be public HTTPS.
# Example: https://inventory.example.com
# -----------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_BASE_URL=
TELEGRAM_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# Optional: local storage override
# Leave blank to use Docker volumes.
# -----------------------------------------------------------------------------
RECEIPTS_DIR=
