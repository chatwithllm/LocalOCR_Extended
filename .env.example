# =============================================================================
# LocalOCR Extended
# Copy this file to .env, then fill in the values below.
# This file is safe to commit. Never commit your real .env.
# =============================================================================

# -----------------------------------------------------------------------------
# Required: App access
# -----------------------------------------------------------------------------
# Generate once with:
# python -c "import secrets; print(secrets.token_urlsafe(32))"
# The first browser login uses the email/password below.
# INITIAL_ADMIN_TOKEN remains useful for integrations and direct API calls.
INITIAL_ADMIN_TOKEN=replace_with_a_long_random_token
INITIAL_ADMIN_NAME=Admin
INITIAL_ADMIN_EMAIL=admin@localhost
INITIAL_ADMIN_PASSWORD=replace_with_a_strong_password
SESSION_SECRET=replace_with_another_long_random_secret
SESSION_COOKIE_SECURE=0

# -----------------------------------------------------------------------------
# Required: Primary OCR provider
# -----------------------------------------------------------------------------
GEMINI_API_KEY=replace_with_your_gemini_api_key
GEMINI_MODEL=gemini-2.5-flash

# -----------------------------------------------------------------------------
# Optional: Secondary OCR fallback
# Leave blank if you do not want OpenAI fallback.
# -----------------------------------------------------------------------------
OPENAI_API_KEY=
OPENAI_OCR_MODEL=gpt-4.1-mini

# -----------------------------------------------------------------------------
# Optional: Ollama fallback OCR
# Extended is designed to run in parallel with the stable grocery app.
# Default points at the shared Ollama service published by that stack.
# If you run Ollama on another machine, replace with that LAN URL.
# Example: http://192.168.1.50:11434
# -----------------------------------------------------------------------------
OLLAMA_ENDPOINT=http://host.docker.internal:11434
OLLAMA_MODEL=llava:7b
OLLAMA_TIMEOUT_SECONDS=180

# -----------------------------------------------------------------------------
# App runtime
# -----------------------------------------------------------------------------
FLASK_ENV=production
FLASK_PORT=8090
FLASK_DEBUG=0
APP_SERVICE_NAME=localocr-extended-backend
APP_DISPLAY_NAME=LocalOCR Extended
APP_SLUG=localocr_extended
DATABASE_URL=sqlite:////data/db/localocr_extended.db
BACKUP_DIR=/data/backups
BACKUP_PREFIX=localocr_extended
RECOMMENDATION_TIME=08:00
RECEIPT_RETENTION_MONTHS=12

# -----------------------------------------------------------------------------
# MQTT / Home Assistant
# Extended shares the existing grocery broker by default.
# Set MQTT_BROKER=mqtt only if you start the optional local-infra profile here.
# -----------------------------------------------------------------------------
MQTT_BROKER=host.docker.internal
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_CLIENT_ID=localocr-extended
MQTT_TOPIC_PREFIX=home/localocr_extended
MQTT_DISCOVERY_ENABLED=true
HOME_ASSISTANT_DISCOVERY_PREFIX=homeassistant

# -----------------------------------------------------------------------------
# Optional operator notes for Home Assistant integration
# These are placeholders for the person deploying the app.
# They are not currently required by the backend code.
# -----------------------------------------------------------------------------
HOME_ASSISTANT_BASE_URL=http://homeassistant.local:8123
HOME_ASSISTANT_DASHBOARD_PATH=/lovelace/localocr-extended

# -----------------------------------------------------------------------------
# Optional: Telegram bot
# Needed only if you want to send receipts through Telegram.
# TELEGRAM_WEBHOOK_BASE_URL must be public HTTPS.
# Example: https://inventory.example.com
# -----------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_BASE_URL=
TELEGRAM_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# Optional: local storage override
# Leave blank to use Docker volumes.
# -----------------------------------------------------------------------------
RECEIPTS_DIR=/data/receipts

# -----------------------------------------------------------------------------
# Required for encrypted credentials (admin-stored AI provider API keys via
# Settings → AI Models with credential_mode=stored_key, plus future external
# integrations). Generate ONCE per environment and never rotate without
# re-encrypting existing rows.
#
# Easiest (works on any OS, container already has cryptography installed):
#   docker exec localocr-extended-backend \
#       python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
#
# Or generate on the host (see README → Configuration → Encrypted credentials
# for per-OS install instructions).
#
# Paste the 44-char base64 key after the = sign. Use a different key in dev
# vs prod. Treat it like a password — losing it makes stored secrets
# unreadable, requiring you to re-enter them in the admin UI.
# -----------------------------------------------------------------------------
FERNET_SECRET_KEY=
